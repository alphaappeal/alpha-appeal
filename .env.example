# Alpha Appeal - Environment Variables Configuration
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =====================================================
# SUPABASE CONFIGURATION (Required)
# =====================================================
VITE_SUPABASE_PROJECT_ID="xlyxtbcqirspcfxdznyu"
VITE_SUPABASE_URL="https://xlyxtbcqirspcfxdznyu.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key_here"

# For Edge Functions development (local)
SUPABASE_ANON_KEY="your_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# =====================================================
# PAYMENT PROCESSING (PayFast)
# =====================================================
# Get these from https://www.payfast.co.za/settings/developers/
PAYFAST_MERCHANT_ID="10000100"
PAYFAST_MERCHANT_KEY="your_merchant_key_here"
PAYFAST_PASSPHRASE="your_passphrase_here"

# PayFast Environment
# Use sandbox for testing: https://sandbox.payfast.co.za/eng/process
# Use production for live: https://www.payfast.co.za/eng/process
PAYFAST_ENVIRONMENT="sandbox"  # or "production"

# =====================================================
# EMAIL MARKETING (MailerLite)
# =====================================================
# Get API key from https://www.mailerlite.com/integrations/api
MAILERLITE_API_KEY="your_api_key_here"

# MailerLite Group IDs (create groups in MailerLite dashboard)
MAILERLITE_GROUP_ESSENTIAL="group_id_essential"
MAILERLITE_GROUP_ELITE="group_id_elite"
MAILERLITE_GROUP_PRIVATE="group_id_private"

# =====================================================
# SHIPPING & DELIVERY (Shipday)
# =====================================================
SHIPDAY_API_KEY="your_api_key_here"
SHIPDAY_WEBHOOK_SECRET="your_webhook_secret_here"

# =====================================================
# SECURITY & CORS
# =====================================================
# Comma-separated list of allowed origins for Edge Functions
ALLOWED_ORIGINS="https://alpha-appeal.co.za,https://www.alpha-appeal.co.za"

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000        # 1 minute
RATE_LIMIT_MAX_REQUESTS=10        # Max requests per window

# =====================================================
# APPLICATION SETTINGS
# =====================================================
NODE_ENV="development"  # or "production"
VITE_APP_VERSION="1.0.0"

# Feature flags
VITE_ENABLE_AGE_GATE="true"
VITE_ENABLE_CONSENT_MODAL="true"

# Analytics (optional)
# VITE_GA_TRACKING_ID="G-XXXXXXXXXX"
# VITE_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# =====================================================
# DEVELOPMENT SETTINGS
# =====================================================
# Local development server
PORT=8080

# Enable React DevTools
VITE_REACT_DEVTOOLS="true"

# =====================================================
# INSTRUCTIONS
# =====================================================
# 1. Copy this file to .env.local
#    cp .env.example .env.local
# 
# 2. Fill in all values with your actual credentials
# 
# 3. For Edge Functions production deployment:
#    - Go to Supabase Dashboard → Settings → Edge Functions
#    - Add each environment variable there
#    - Mark sensitive values as encrypted
# 
# 4. Never commit .env.local to git!
#    This file is already in .gitignore
# 
# 5. To get your Supabase keys:
#    - Go to https://app.supabase.com/project/xlyxtbcqirspcfxdznyu/settings/api
#    - Copy the Project URL to VITE_SUPABASE_URL
#    - Copy the anon/public key to VITE_SUPABASE_PUBLISHABLE_KEY
#    - Copy the service_role key to SUPABASE_SERVICE_ROLE_KEY (keep secret!)
# 
# =====================================================
# TROUBLESHOOTING
# =====================================================
# If Edge Functions fail with CORS errors:
# - Check ALLOWED_ORIGINS includes your frontend URL
# - Ensure function returns proper CORS headers
# 
# If PayFast payments fail:
# - Verify merchant credentials are correct
# - Check PAYFAST_ENVIRONMENT matches your use case
# - Ensure ITN webhook is configured in PayFast dashboard
# 
# If MailerLite sync fails:
# - Verify API key is valid
# - Check group IDs exist in MailerLite
# - Ensure users have consented to emails
